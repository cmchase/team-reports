# Jira Weekly Reports Configuration Template
# Copy this file to .env and fill in your actual credentials

# Your Jira server URL (include https://)
JIRA_SERVER=https://your-company.atlassian.net

# Your Jira email address
JIRA_EMAIL=your-email@company.com

# Your Jira API token
# For Atlassian Cloud: Account Settings → Security → API tokens → Create token
# For Jira Server/Data Center: Profile → Personal Access Tokens → Create token
JIRA_API_TOKEN=your-api-token-here

# GitHub Personal Access Token for GitHub reports
# Go to: GitHub Settings → Developer settings → Personal access tokens → Tokens (classic) → Generate new token
# Required scopes: repo (for private repos), public_repo (for public repos), read:org
GITHUB_TOKEN=your-github-personal-access-token-here

# GitLab Personal Access Token (optional; for GitLab reports, e.g. self-hosted/VPN)
# When using config/gitlab_config.yaml with base_url and projects, set this for API access.
# Create at: GitLab → User Settings → Access Tokens; scope: read_api
GITLAB_TOKEN=your-gitlab-token-here

